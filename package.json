{
  "name": "manufacturing-process-authenticity",
  "version": "1.0.0",
  "description": "Manufacturing Process Production Authenticity System",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "install-all": "npm install && cd client && npm install && cd .. && cd server && npm install",
    "build": "cd client && npm run build",
    "build:server": "cd server && npm install --omit=dev",
    "start": "cd server && node index.js",
    "test": "cd server && npm test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {},
  "devDependencies": {
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.2"
  }
}
